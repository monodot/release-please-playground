#!/usr/bin/env bash
#
# commit-msg hook that enforces Conventional Commits.
#
# Enable it once per clone with:
#   git config core.hooksPath .githooks
#
set -euo pipefail

msg_file="$1"
header="$(head -n1 "$msg_file")"

# Let merge and revert commits through untouched.
if printf '%s' "$header" | grep -qE '^(Merge|Revert) '; then
  exit 0
fi

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?!?: .+'

if ! printf '%s' "$header" | grep -qE "$pattern"; then
  echo "ERROR: your commit message does not follow Conventional Commits." >&2
  echo >&2
  echo "  Your message: $header" >&2
  echo >&2
  echo "  Expected:     <type>(<scope>): <description>" >&2
  echo "  Example:      feat(frontend): add a dark mode toggle" >&2
  echo >&2
  echo "  Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert" >&2
  echo "  Scope is optional. Add ! after the type or scope for a breaking change." >&2
  exit 1
fi
